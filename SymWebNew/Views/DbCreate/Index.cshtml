@model SymViewModel.Common.DbCreateVM
@using UIHelper.MVC

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Database Create Form</title>

    <style>
    </style>

</head>
<body>
   
        <div style="max-height:250px!important" class="content">
            <div class=" ">
                <div class="row">
                    <div class="col-md-4 col-sm-12 col-xs-12">
                    </div>
                    <div id="login" class="col-md-4 col-sm-10 col-xs-10">
                        <div class="login">
                            <div class="col-md-10">
                                @using (Html.BeginForm("", "DbCreate", FormMethod.Post, new { enctype = "multipart/form-data", id = "frmLogin" }))
                                {
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                                    @Html.LabelFor(model => model.LogIN)
                                    @Html.TextBoxFor(model => model.LogIN, new { placeholder = "Log IN", required = "required", @class = "uid form-control" })

                                    @Html.LabelFor(model => model.Password)
                                    @Html.PasswordFor(model => model.Password, new { placeholder = "Password", required = "required", @class = "form-control" })

                                    @Html.LabelFor(model => model.ServerName)
                                    @Html.TextBoxFor(model => model.ServerName, new { placeholder = "Server Name", required = "required", @class = "form-control" })

                                    @Html.LabelFor(model => model.DatabaseName)
                                    @Html.TextBoxFor(model => model.DatabaseName, new { placeholder = "Database Name", required = "required", @class = "form-control" })
                                    <br />
                                    <button type="submit" formaction="@Url.Action("TestConnection", "DbCreate")" class="btn btn-primary btn-block btn-large"> Test Connection</button>
                                    <br />
                                    <button type="submit" formaction="@Url.Action("Create", "DbCreate")"class="btn btn-success btn-block btn-large">Save</button>
                                }
                            </div>
                        </div>

                    </div>
                </div>
        </div>
        </div>
        <span id="ip"></span>
</body>

