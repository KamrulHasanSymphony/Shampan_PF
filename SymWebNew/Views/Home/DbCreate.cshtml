@model SymViewModel.Common.DbCreateVM
@using UIHelper.MVC

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Databae Create Form</title>

    <style>
    </style>

</head>
<body>
    <div style="max-height:250px!important" class="content">
        <div class=" ">
            <div id="login" class="col-md-4 col-sm-12 col-xs-12">
                <div class="login">
                    <div class="col-md-10">
                        @using (Html.BeginForm("DbCreate", "Home", new {  enctype = "multipart/form-data", @Id = "frmLogin" }))
                        {
                            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                           
                            @Html.LabelFor(model => model.LogIN, new { @class = "" })
                            @Html.TextBoxFor(model => model.LogIN, new { placeholder = "sa", required = "required", @class = "uid form-control" })
                            @Html.LabelFor(model => model.Password, new { @class = "" })
                            @Html.PasswordFor(model => model.Password, new { placeholder = "Password", required = "required", @class = "form-control" })
                            @Html.LabelFor(model => model.ServerName, new { @class = "" })
                            @Html.PasswordFor(model => model.ServerName, new { placeholder = "Server Name", required = "required", @class = "form-control" })
                            @Html.LabelFor(model => model.DatabaseName, new { @class = "" })
                            @Html.PasswordFor(model => model.DatabaseName, new { placeholder = "Database Name", required = "required", @class = "form-control" })
                            <button type="submit" class="btn btn-primary btn-block btn-large">Save</button>
                            <button type="submit" class="btn btn-primary btn-block btn-large">Test Connection</button>
                        }
                    </div>
                </div>



            </div>
        </div>
    </div>
    @*  <div class="content">
            @Html.Partial("_footerView")
        </div>*@
    <span id="ip"></span>


</body>

